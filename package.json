{
  "name": "aess-settlement-system",
  "version": "1.0.0",
  "description": "AESS - Autonomous Execution and Settlement System for AI agent work verification and on-chain escrow",
  "private": false,
  "type": "module",
  "main": "dist/server.cjs",
  "types": "dist/types/index.d.ts",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "npm run build:contracts && npm run build:app",
    "build:app": "vite build && esbuild src/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:contracts": "hardhat compile",
    "start": "node dist/server.cjs",
    "demo": "tsx src/utils/demoRunner.ts",
    "demo:verbose": "DEBUG=* tsx src/utils/demoRunner.ts",
    "check:balance": "tsx scripts/checkBalance.ts",
    "check:escrow": "tsx scripts/checkEscrow.ts",
    "check:wallet": "tsx -e \"import 'dotenv/config'; import { ethers } from 'ethers'; const w = new ethers.Wallet(process.env.PHAROS_PRIVATE_KEY); console.log('Wallet Address:', w.address);\"",
    "deploy:contract": "hardhat run scripts/deploy.js --network pharos",
    "deploy:verify": "hardhat verify --network pharos",
    "compile": "hardhat compile",
    "clean": "hardhat clean && rm -rf dist cache artifacts",
    "lint": "tsc --noEmit",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}'",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:contracts": "hardhat test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install || true",
    "postinstall": "npm run compile"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.17.0",
    "express": "^4.21.2",
    "fastify": "^5.8.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.13",
    "@openzeppelin/contracts": "^5.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^9.18.0",
    "hardhat": "^2.22.17",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "blockchain",
    "escrow",
    "ai-verification",
    "smart-contracts",
    "autonomous-agents",
    "settlement",
    "gemini-ai",
    "web3",
    "defi",
    "pharos",
    "ethereum",
    "typescript"
  ],
  "author": {
    "name": "Great-ify",
    "url": "https://github.com/Great-ify"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Great-ify/Autonomous-Execution-Settlement-Skill.git"
  },
  "bugs": {
    "url": "https://github.com/Great-ify/Autonomous-Execution-Settlement-Skill/issues",
    "email": "support@aess.network"
  },
  "homepage": "https://github.com/Great-ify/Autonomous-Execution-Settlement-Skill#readme",
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/Great-ify"
  },
  "files": [
    "dist",
    "contracts",
    "src",
    "scripts",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ]
}